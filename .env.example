# Leave this as mock for a key-free local canvas.
AI_PROVIDER=mock

# 302.AI server-only configuration. Put real values in .env.local, never in NEXT_PUBLIC_ variables.
AI_302_API_KEY=
AI_302_API_ORIGIN=https://api.302.ai
AI_302_BASE_URL=https://api.302.ai/v1
AI_302_OPENAI_BASE_URL=https://api.302.ai/v1

# Model defaults
AI_302_TEXT_MODEL=gpt-4o-mini
AI_302_STORYBOARD_MODEL=gpt-4o-mini
AI_302_IMAGE_MODEL=gpt-image-2
AI_302_VIDEO_MODEL=minimaxi-t2v-01
AI_302_TTS_MODEL=doubao
AI_302_TTS_VOICE=zh_male_beijingxiaoye_emo_v2_mars_bigtts

# Request behavior
AI_302_TIMEOUT_MS=120000
AI_302_POLL_INTERVAL_MS=3000

# Video provider: mock | 302ai | tokenstar. Keep TOKENSTAR_API_KEY server-only.
AI_VIDEO_PROVIDER=mock
TOKENSTAR_API_KEY=
TOKENSTAR_API_ORIGIN=https://api.tokenstar.world
TOKENSTAR_VIDEO_MODEL=seedance-2.0-fast
TOKENSTAR_VIDEO_ASSET_MODEL=seedance-2.0-asset-fast
TOKENSTAR_KLING_MODEL=kling-v3
TOKENSTAR_KLING_OMNI_MODEL=kling-v3-omni
TOKENSTAR_KLING_MODE=std
TOKENSTAR_KLING_ELEMENT_TAG_ID=o_105
TOKENSTAR_DEFAULT_RATIO=16:9
TOKENSTAR_DEFAULT_DURATION=8
TOKENSTAR_DEFAULT_RESOLUTION=720p
TOKENSTAR_GENERATE_AUDIO=true
TOKENSTAR_POLL_INTERVAL_MS=12000
TOKENSTAR_MAX_POLL_ATTEMPTS=80
TOKENSTAR_ASSET_POLL_INTERVAL_MS=1500
TOKENSTAR_ASSET_MAX_POLL_ATTEMPTS=20
